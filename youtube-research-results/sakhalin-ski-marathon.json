      "title": "\u041b\u044b\u0436\u043d\u044b\u0439 \u043c\u0430\u0440\u0430\u0444\u043e\u043d \u043f\u0430\u043c\u044f\u0442\u0438 \u0418\u0433\u043e\u0440\u044f \u0424\u0430\u0440\u0445\u0443\u0442\u0434\u0438\u043d\u043e\u0432\u0430. \u0421\u0430\u0445\u0430\u043b\u0438\u043d 2018",
      "channel": "\u0413\u0430\u0437\u043f\u0440\u043e\u043c \u0442\u0440\u0430\u043d\u0441\u0433\u0430\u0437 \u0422\u043e\u043c\u0441\u043a",
