+            panels.append(f'<div class="gl-tab-panel{active}" id="{uid}-{i}">{_paragraphs(tab.get("content", ""), source_ids)}</div>')
+        return f'<div class="gl-guide-block gl-tabs"><div class="gl-tab-buttons">{"".join(buttons)}</div>{"".join(panels)}</div>'
+    if kind == "accordion":
