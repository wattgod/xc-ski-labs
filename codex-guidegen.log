+{build_chapter_body(chapter, content)}
+{build_prev_next(chapter, content["chapters"])}
+</main>
+</div>
+<div class="gl-page">{build_footer({})}</div>
+"""
+    return assemble_page(
+        title,
+        description,
+        robots,
+        body,
+        build_jsonld(title, description, f'https://xcskilabs.com/guide/{chapter["id"]}/'),
