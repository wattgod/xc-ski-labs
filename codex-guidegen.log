+    next_ch = next((c for c in chapters if c["number"] == chapter["number"] + 1), None)
+    left = '<div></div>' if not prev_ch else f'<a href="/guide/{esc(prev_ch["id"])}/"><span>Previous</span>Ch {prev_ch["number"]}: {esc(prev_ch["title"])}</a>'
